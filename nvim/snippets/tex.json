{
  "Begin-End Environment": {
    "prefix": "begin",
    "body": [
      "\\begin{${1:environment}}",
      "\t$0",
      "\\end{$1}"
    ],
    "description": "LaTeX begin/end block"
  },
  "Equation": {
    "prefix": "beq",
    "body": [
      "\\begin{equation}",
      "\t$0",
      "\\end{equation}"
    ],
    "description": "Numbered equation"
  },
  "Equation*": {
    "prefix": "beq*",
    "body": [
      "\\begin{equation*}",
      "\t$0",
      "\\end{equation*}"
    ],
    "description": "Unnumbered equation"
  },
  "Align": {
    "prefix": "bal",
    "body": [
      "\\begin{align}",
      "\t$0",
      "\\end{align}"
    ],
    "description": "Align environment"
  },
  "Align*": {
    "prefix": "bal*",
    "body": [
      "\\begin{align*}",
      "\t$0",
      "\\end{align*}"
    ],
    "description": "Unnumbered align"
  },
  "Cases": {
    "prefix": "bca",
    "body": [
      "\\begin{cases}",
      "\t$1 & \\text{if } $2 \\\\",
      "\t$3 & \\text{if } $4",
      "\\end{cases}$0"
    ],
    "description": "Cases environment"
  },
  "Inline Math": {
    "prefix": "mm",
    "body": "$${1}$$0",
    "description": "Inline math"
  },
  "Display Math": {
    "prefix": "dm",
    "body": [
      "$$",
      "$0",
      "$$"
    ],
    "description": "Display math block"
  }
}
