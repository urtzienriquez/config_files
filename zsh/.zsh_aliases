# reload zsh
alias zr='source ~/.config/zsh/.zshrc'

# neovim alternative config aliases
alias nv-neoffice='NVIM_APPNAME=nvim_neoffice nvim'

# nv switcher
function nvs() {
  local items=("default" "normal" "neoffice")
  local config
  config=$(printf "%s\n" "${items[@]}" | fzf --prompt=" config: " --height=20% --layout=reverse --border --exit-0)
  if [[ -z $config ]]; then
    echo "Nothing selected"
    return 0
  fi
  case $config in
    default)
      nvim --clean "$@"
      ;;
    normal)
      nvim "$@"
      ;;
    *)
      NVIM_APPNAME="nvim_$config" nvim "$@"
      ;;
  esac
}

# update neovim
nvup() {
    local nvim_dir="/home/urtzi/Documents/GitHub/neovim/"
    echo "Updating neovim from $nvim_dir..."
    cd "$nvim_dir" || return 1
    git pull && \
    make distclean && \
    make CMAKE_BUILD_TYPE=RelWithDebInfo && \
    sudo make install && \
    echo "✓ Neovim updated successfully!"
    cd - > /dev/null
}

# update wezterm
wtup() {
    local wt_dir="$HOME/Documents/GitHub/wezterm"
    
    # 1. Update or Clone source
    if [ ! -d "$wt_dir" ]; then
        echo "Cloning wezterm to $wt_dir..."
        git clone --depth=1 --branch=main --recursive https://github.com/wezterm/wezterm.git "$wt_dir" || return 1
        cd "$wt_dir" || return 1
    else
        echo "Updating wezterm from $wt_dir..."
        cd "$wt_dir" || return 1
        # Pull latest and update submodules (critical for zlib/dependencies)
        git pull && git submodule update --init --recursive || return 1
    fi

    # 2. Build process using cargo
    ./get-deps && \
    cargo build --release || return 1
    
    # 3. Install binaries to /usr/local/bin
    sudo cp target/release/wezterm /usr/local/bin/wezterm && \
    sudo cp target/release/wezterm-gui /usr/local/bin/wezterm-gui && \
    sudo cp target/release/wezterm-mux-server /usr/local/bin/wezterm-mux-server && \
    sudo cp target/release/strip-ansi-escapes /usr/local/bin/strip-ansi-escapes && \

    # 4. Desktop integration (Menu icon and launcher)
    if [ -d "assets/icon" ]; then
        sudo mkdir -p /usr/share/icons/hicolor/128x128/apps/
        sudo cp assets/icon/terminal.png /usr/share/icons/hicolor/128x128/apps/org.wezfurlong.wezterm.png
        sudo cp assets/wezterm.desktop /usr/share/applications/org.wezfurlong.wezterm.desktop
        sudo update-desktop-database
    fi

    # 5. Update Terminfo (Ensures SSH works correctly)
    if [ -f "assets/terminfo" ]; then
        tic -x -o ~/.terminfo assets/terminfo
    fi

    # 6. Generate Zsh Completions
    mkdir -p "$HOME/.config/zsh/completions"
    ./target/release/wezterm shell-completion --shell zsh > "$HOME/.config/zsh/completions/_wezterm"

    echo "✓ WezTerm updated successfully!"
    cd - > /dev/null
}

# update qutebrowser
qbup() {
    local qb_dir="/opt/qutebrowser"
    echo "Updating qutebrowser from $qb_dir..."
    cd "$qb_dir" || return 1
    git pull && \
    sudo /opt/qutebrowser/scripts/mkvenv.py --update --pyqt-type link && \
    echo "✓ qutebrowser updated successfully!"
    cd - > /dev/null
}

