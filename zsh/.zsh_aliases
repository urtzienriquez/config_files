# reload zsh
alias zr='source ~/.config/zsh/.zshrc'

# neovim alternative config aliases
alias nv-neoffice='NVIM_APPNAME=nvim_neoffice nvim'

# nv switcher
function nvs() {
  local items=("default" "normal" "neoffice")
  local config
  config=$(printf "%s\n" "${items[@]}" | fzf --prompt=" config: " --height=20% --layout=reverse --border --exit-0)
  if [[ -z $config ]]; then
    echo "Nothing selected"
    return 0
  fi
  case $config in
    default)
      nvim --clean "$@"
      ;;
    normal)
      nvim "$@"
      ;;
    *)
      NVIM_APPNAME="nvim_$config" nvim "$@"
      ;;
  esac
}

# update neovim
nvup() {
    local nvim_dir="/home/urtzi/Documents/GitHub/neovim/"
    echo "Updating neovim from $nvim_dir..."
    cd "$nvim_dir" || return 1
    git pull && \
    make distclean && \
    make CMAKE_BUILD_TYPE=RelWithDebInfo && \
    sudo make install && \
    echo "✓ Neovim updated successfully!"
    cd - > /dev/null
}

# update tmux
tmuxup() {
    local tmux_dir="/home/urtzi/Documents/GitHub/tmux/"
    echo "Updating tmux from $tmux_dir..."
    cd "$tmux_dir" || return 1
    git pull && \
    make && \
    sudo make install && \
    echo "✓ tmux updated successfully!"
    cd - > /dev/null
}

# update ghostty
ghosttyup() {
    local ghostty_dir="/home/urtzi/Documents/GitHub/ghostty"
    echo "Updating Ghostty from $ghostty_dir..."
    
    cd "$ghostty_dir" || return 1
    
    # 1. Pull latest code
    # 2. Update submodules (crucial for Ghostty)
    # 3. Clean previous build artifacts
    # 4. Build and install to ~/.local
    git pull && \
    git submodule update --init --recursive && \
    command rm -rf .zig-cache zig-out && \
    zig build -p "$HOME/.local" -Doptimize=ReleaseFast && \
    echo "✓ Ghostty updated successfully!"
    
    cd - > /dev/null
}

# update qutebrowser
qbup() {
    local qb_dir="/opt/qutebrowser"
    echo "Updating qutebrowser from $qb_dir..."
    cd "$qb_dir" || return 1
    git pull && \
    sudo /opt/qutebrowser/scripts/mkvenv.py --update --pyqt-type link && \
    echo "✓ qutebrowser updated successfully!"
    cd - > /dev/null
}

