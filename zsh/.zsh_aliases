# alias for yazi
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	command rm -f -- "$tmp"
}

# alias for bat
alias bt='bat -p'

# fd as fdfind (in Debian it is called just with fdfind)
alias fd='fdfind'

# sf: search files in given path (or current path if not specified), open appropriately
sf() {
  local search_path="${1:-.}"
  local file
  file=$(fd . "$search_path" \
    -HI \
    --type f \
    --exclude node_modules \
    --exclude .git \
    --exclude "$HOME/go" | \
    fzf --reverse --info=right --preview 'bat -p --color=always {} 2>/dev/null') || return

  local mime
  mime=$(file -b --mime-type "$file")

  if [[ $mime == text/html ]]; then
    qutebrowser --qt-arg class web --qt-arg name web "$file" &
  elif [[ $mime == text/* || $mime == application/javascript ]]; then
    nvim "$file"
  elif [[ -x "$file" ]]; then
    gio open "$file"
  elif [[ $mime == video/* ]]; then
    mpv "$file"
  else
    gio open "$file"
  fi
}
sf_widget() {
  sf
  zle reset-prompt
}
zle -N sf_widget

# sd: search dirs in given path (or current path if not specified), and cd appropriately
sd() {
  local search_path="${1:-.}"
  local dir
  dir=$(fd . "$search_path" \
    -HI \
    --type d \
    --exclude node_modules \
    --exclude .git \
    --exclude "$HOME/go" | \
    fzf --reverse --info=right) || return

  cd "$dir"
}
sd_widget() {
  sd
  zle reset-prompt
}
zle -N sd_widget

# sx: search files and dirs in given path (or current path if not specified), and cd appropriately
sx() {
  local search_path="${1:-.}"
  local selected
  selected=$(fd . "$search_path" \
    -HI \
    --type f --type d \
    --exclude node_modules \
    --exclude .git \
    --exclude "$HOME/go" | \
    fzf --reverse --info=right --preview 'bat -p --color=always {} 2>/dev/null') || return

  if [[ -d "$selected" ]]; then
    cd "$selected"
  else
    cd "$(dirname "$selected")"
  fi
}
sx_widget() {
  sx
  zle reset-prompt
}
zle -N sx_widget

# sr: search git repos in given path (or $HOME if not specified), and cd appropriately
sr() {
  local search_path="${1:-$HOME}"
  local dir
  dir=$(fd -HI --type d --glob '.git' "$search_path" \
    | sed 's|/\.git||' \
    | fzf --reverse --info=right --prompt='git repos > ') || return
  cd "$dir"
}
sr_widget() {
  sr
  zle reset-prompt
}
zle -N sr_widget

# sfr: like sf but searches the whole system with locate
sfr() {
  local file
  file=$(locate / | while read -r f; do [[ -f "$f" ]] && echo "$f"; done | \
    fzf --reverse --info=right --preview 'bat -p --color=always {} 2>/dev/null') || return

  local mime
  mime=$(file -b --mime-type "$file")

  if [[ $mime == text/html ]]; then
    qutebrowser --qt-arg class web --qt-arg name web "$file" &
  elif [[ $mime == text/* || $mime == application/javascript ]]; then
    nvim "$file"
  elif [[ -x "$file" ]]; then
    gio open "$file"
  elif [[ $mime == video/* ]]; then
    mpv "$file"
  else
    gio open "$file"
  fi
}
srf_widget() {
  sfr
  zle reset-prompt
}
zle -N srf_widget

# sdr: like sd but searches entire system using locate, and cd accordingly
sdr() {
  local dir
  dir=$(locate / | while read -r p; do
      [[ -d "$p" ]] && printf '%s\n' "$p"
    done | fzf --reverse --info=right) || return

  cd "$dir"
}
srd_widget() {
  sdr
  zle reset-prompt
}
zle -N srd_widget

# sxr: like sx but searches entire system using locate, and cd accordingly
sxr() {
  local selected
  selected=$(locate / | fzf --reverse --info=right --preview 'bat -p --color=always {} 2>/dev/null') || return

  if [[ -d "$selected" ]]; then
    cd "$selected"
  else
    cd "$(dirname "$selected")"
  fi
}
srx_widget() {
  sxr
  zle reset-prompt
}
zle -N srx_widget

# tmux with session name = term name
tm() {
	  tty_id=$(basename "$(tty)")
	  session="term_${tty_id}"
	  tmux new-session -A -s "$session"
}

# Activate virtual env:
# sv: activates ./.venv
# sv myenv: activates ./myenv
# sv /full/path/to/env: activates that env
function sv() {
    local venv_path="${1:-.venv}"

    if [ -f "$venv_path/bin/activate" ]; then
        source "$venv_path/bin/activate"
        tmux set-environment VIRTUAL_ENV $VIRTUAL_ENV &&
        alias deactivate='\deactivate && tmux set-environment -u VIRTUAL_ENV && unalias deactivate'
    else
        echo "No virtualenv found at: $venv_path"
        return 1
    fi
}

# start screenkey with transparent background
function kon() {
    screenkey > /dev/null 2>&1 &
    disown
}

# stop screenkey
function koff() {
    pkill -f screenkey
}

# get paper template
function rticle() {
    git clone https://github.com/urtzienriquez/paper_template ./manuscript
    command rm -rf manuscript/(.git|README.md)
}

# render quarto and fix paths for hugo site
quarto-hugo() {
    local filename="${1%.*}"  # Remove extension if present
    quarto render "$1" && ~/Documents/GitHub/urtzienriquez.github.io/util/fix-hugo-images.sh "${filename}.md"
}

